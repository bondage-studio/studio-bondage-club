<?xml version="1.0" encoding="utf-8"?>
<!--
  The WebView talks to the in-process server over plain HTTP on the loopback
  interface, so cleartext is permitted only for localhost. The server's own
  upstream fetches use its bundled OpenSSL and are unaffected by this policy.
  Everything else keeps the platform default (cleartext denied).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
